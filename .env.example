# Banco de dados (Prisma usa DATABASE_URL diretamente)
DATABASE_URL=postgresql://legua:senha@db:5432/legua
POSTGRES_USER=legua
POSTGRES_PASSWORD=senha
POSTGRES_DB=legua

# Sessao do estudante
SESSION_SECRET=string-longa-e-aleatoria-minimo-32-caracteres-troque-em-producao
SESSION_MAX_AGE=604800

# Sessao do administrador (secret separado do estudante)
ADMIN_SESSION_SECRET=outra-string-longa-e-aleatoria-minimo-32-caracteres-troque-em-producao
ADMIN_SESSION_MAX_AGE=28800

# Admin inicial criado pelo seed
ADMIN_INITIAL_EMAIL=admin@legua.com.br
ADMIN_INITIAL_PASSWORD=change

# Admins do Ciclo 1 (seed de exemplo)
ORG_ADMIN_INITIAL_EMAIL=org@legua.com.br
ORG_ADMIN_INITIAL_PASSWORD=change
ESCOLA_ADMIN_INITIAL_EMAIL=escola@legua.com.br
ESCOLA_ADMIN_INITIAL_PASSWORD=change

# Aplicacao
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Object storage (MinIO / S3-compativel)
# Dev local (MinIO do docker-compose): endpoint e URL publica em localhost:9000.
# Em producao (Coolify): S3_ENDPOINT = rede interna; S3_PUBLIC_URL = dominio publico.
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_URL=http://localhost:9000/legua-public
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_PUBLIC=legua-public
S3_BUCKET_PRIVATE=legua-private
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_TTL=3600

# Credenciais do MinIO local (usadas pelo docker-compose)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
